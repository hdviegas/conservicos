APP_NAME=CONSERVICOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://conservicos.hil.dev.br
APP_PORT=9991

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=conservicos
DB_USERNAME=conservicos_app
DB_PASSWORD=troque-por-senha-forte-app

# MySQL container credentials (bootstrap only)
MYSQL_ROOT_PASSWORD=troque-por-senha-forte-root
MYSQL_APP_USERNAME=conservicos_app
MYSQL_APP_PASSWORD=troque-por-senha-forte-app

# ─── Sessions & Cache ────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_HOST_PORT=6381

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@conservicos.com.br"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
